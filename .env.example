# Optional: enables AI news summaries and analysis narratives.
# Without it, FinSight still works — insights come from transparent rules.
ANTHROPIC_API_KEY=

# Optional overrides
FINSIGHT_AI_MODEL=claude-sonnet-5
FINSIGHT_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FINSIGHT_CACHE_TTL=300

# Persistence (SQLite is the application default when this is unset).
# This value matches the PostgreSQL service in docker-compose.yml.
FINSIGHT_DATABASE_URL=postgresql+psycopg://finsight:finsight@localhost:5432/finsight
